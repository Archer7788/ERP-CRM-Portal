{
  "name": "erp-crm-operations-portal",
  "version": "1.0.0",
  "description": "ERP + CRM Operations Portal backend - Node.js, TypeScript, Express, PostgreSQL, JWT + RBAC, AWS S3, PDF invoices",
  "main": "dist/server.js",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "rimraf dist && tsc -p tsconfig.json && npm run copy:assets",
    "copy:assets": "mkdir -p dist/database/migrations && cp -r src/database/migrations/. dist/database/migrations/",
    "start": "node dist/server.js",
    "migrate": "ts-node src/database/migrate.ts",
    "migrate:prod": "node dist/database/migrate.js",
    "seed": "ts-node src/database/seed.ts",
    "seed:prod": "node dist/database/seed.js",
    "db:setup": "npm run migrate && npm run seed",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["erp", "crm", "inventory", "challan", "express", "typescript", "postgresql"],
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-s3": "^3.637.0",
    "@aws-sdk/s3-request-presigner": "^3.637.0",
    "bcryptjs": "^2.4.3",
    "compression": "^1.7.4",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^2.0.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.7.5",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.10",
    "@types/pdfkit": "^0.13.4",
    "@types/pg": "^8.11.6",
    "rimraf": "^5.0.9",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.5.4"
  }
}
