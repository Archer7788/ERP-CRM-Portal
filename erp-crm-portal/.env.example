# ---------------------------------------------------------------------------
# ERP + CRM Operations Portal - Environment Configuration
# Copy this file to `.env` and fill in real values. NEVER commit `.env`.
# ---------------------------------------------------------------------------

# ---- Application ----------------------------------------------------------
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1
CORS_ORIGIN=*

# ---- Database (PostgreSQL) ------------------------------------------------
DATABASE_URL=postgresql://postgres:friday%40%2A%2488@localhost:5432/erp_crm_portal
DB_SSL=false
DB_POOL_MAX=10

# ---- Authentication (JWT) -------------------------------------------------
JWT_SECRET=k9@Lm4/Qx7!Vp2Rs8$Tw5Yn1Zh6Df3GcJ0Pa&Ku9Me
JWT_EXPIRES_IN=1d
BCRYPT_SALT_ROUNDS=10
LOGIN_RATE_LIMIT_WINDOW_MINUTES=15
LOGIN_RATE_LIMIT_MAX_ATTEMPTS=10

# ---- Pagination defaults --------------------------------------------------
DEFAULT_PAGE_SIZE=20
MAX_PAGE_SIZE=100

# ---- Sales Challan numbering ----------------------------------------------
CHALLAN_NUMBER_PREFIX=CHN
CHALLAN_NUMBER_PADDING=6

# ---- Company details (printed on the PDF invoice) -------------------------
COMPANY_NAME=Acme Distribution Pvt Ltd
COMPANY_ADDRESS=Plot 42, Industrial Estate, Hyderabad, Telangana 500032, India
COMPANY_EMAIL=accounts@acme-distribution.example
COMPANY_PHONE=+91 40 4000 1234
COMPANY_GSTIN=36AABCU9603R1ZX

# ---- AWS S3 (product image upload) ----------------------------------------
AWS_REGION=ap-south-1
AWS_S3_BUCKET=erp-crm-portal-product-images
# Leave the two keys empty when running on EC2/ECS with an IAM role attached.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional CloudFront / custom domain in front of the bucket.
AWS_S3_PUBLIC_BASE_URL=
# When true, objects are kept private and the API returns time-limited signed URLs.
AWS_S3_PRIVATE_OBJECTS=false
AWS_S3_SIGNED_URL_EXPIRY_SECONDS=3600
MAX_UPLOAD_SIZE_MB=5

# ---- Seed data ------------------------------------------------------------
SEED_DEFAULT_PASSWORD=Password@123
